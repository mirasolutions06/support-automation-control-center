# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APPROVAL_PASSCODE=local-approval-passcode
N8N_WEBHOOK_SECRET=change-this-shared-secret

# Optional n8n reviewer notification branch. Set this in n8n when you want
# high-priority or frustrated/angry tickets to alert a human reviewer.
REVIEWER_WEBHOOK_URL=

# Database: Supabase Postgres direct/session pooler URL
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

# AI Provider
AI_PROVIDER=anthropic

# Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Z.ai GLM
# Use AI_PROVIDER=zai to draft with GLM.
ZAI_API_KEY=
ZAI_MODEL=glm-4.7-flash
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_THINKING=disabled

# Optional model cost estimates. Set the provider-specific price per 1M tokens
# from your current plan/provider pricing page.
ANTHROPIC_INPUT_COST_PER_1M=
ANTHROPIC_OUTPUT_COST_PER_1M=
ZAI_INPUT_COST_PER_1M=0
ZAI_OUTPUT_COST_PER_1M=0

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="Support Desk <support@yourdomain.com>"
RESEND_REPLY_TO=

# Keep false until the sender domain/subdomain is verified in Resend.
RESEND_LIVE_SEND=false

# Local fallback
DEMO_FORCE_MEMORY_STORE=false
